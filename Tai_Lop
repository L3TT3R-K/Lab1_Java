    public static void Mang(){
        System.out.println("Nhap so phan tu cua mang: ");
        int n = sc.nextInt();
        int[] arr = new int[n];
        for(int i = 0 ; i < n ; i++){
             int x = sc.nextInt();
             arr[i] = x;
        }
        System.out.print("Mang vua nhap: " + Arrays.toString(arr));
        System.out.println();
        int mmax = -1000000000;
        int mmin = 1000000000;
        for(int i = 0 ; i < n ; i++){
            mmax = Math.max(arr[i], mmax);
            mmin = Math.min(arr[i], mmin);
        }
        System.out.println("Phan tu lon nhat trong mang: " + mmax);
        System.out.println("Phan tu nho nhat trong mang: " + mmin);
        System.out.println("Nhap mot so: ");
        int x = sc.nextInt();
        Arrays.sort(arr);
        int pos = Arrays.binarySearch(arr, x);
        if(pos >= 0){
            System.out.println(x + " co trong mang");
        }
        else System.out.println(x + " khong nam trong mang");
        System.out.println("Nhap mot so: ");
        x = sc.nextInt();
        int dem = 0;
        for(int pt : arr){
            if(x == pt) dem++;
        }
        System.out.println("Co " + dem + " phan tu co gia tri bang " + x + " trong mang");
        Arrays.sort(arr);
        System.out.println("Mang sau khi sap xep tang dan");
        System.out.println(Arrays.toString(arr));
    }
