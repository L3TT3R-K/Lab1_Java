    public static void Prime(){
        System.out.println("Nhap so nguyen duong: ");
        int a = sc.nextInt();
        while(a < 0){
            System.out.println("Can nhap so nguyen duong, nhap lai: ");
            a = sc.nextInt();
        }
        boolean ok = true;
        if(a < 2) ok = false;
        else {
            for (int i = 2; i <= Math.sqrt(a); i++) {
                if (a % i == 0){
                    ok = false;
                    break;
                }
            }
        }
        if(ok) System.out.println(a + " la so nguyen to");
        else System.out.println(a + " khong phai la so nguyen to");
    } 

