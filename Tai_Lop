//3
    public static int UCLN(int a, int b){
        a = Math.abs(a);
        b = Math.abs(b);
        while(b != 0){
            int r = a % b;
            a = b;
            b = r;
        }
        return a;
    }
    public static void inKetQua(int tu, int mau){
        int g = UCLN(tu, mau);
        tu /= g;
        mau /= g;
        if(mau < 0){
            tu = -tu;
            mau = -mau;
        }
        if(tu % mau == 0){
            System.out.println(tu / mau);
        } else {
            System.out.println(tu + "/" + mau);
        }
    }
    public static void PhanSo(){
        System.out.println("Nhap phan so thu nhat: ");
        int a = sc.nextInt();
        int b = sc.nextInt();
        while(b == 0){
            System.out.println("Nhap lai mau so: ");
            b = sc.nextInt();
        }
        System.out.println("Nhap phan so thu hai: ");
        int c = sc.nextInt();
        int d = sc.nextInt();
        while(d == 0){
            System.out.println("Nhap lai mau so: ");
            d = sc.nextInt();
        }
        System.out.println("Tong hai phan so: ");
        inKetQua(a*d + b*c, b*d);
        System.out.println("Hieu hai phan so: ");
        inKetQua(a*d - b*c, b*d);
        System.out.println("Tich hai phan so: ");
        inKetQua(a*c, b*d);
        System.out.println("Thuong hai phan so: ");
        if(c == 0){
            System.out.println("Khong the chia");
        }
        else
        inKetQua(a*d, b*c);
    } 

